<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ClicEat a besoin de votre position pour suivre les livraisons et trouver les restaurants autour de vous.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>En mode "Livreur", ClicEat a besoin de votre position en arrière-plan pour que les clients voient votre progression vers la destination.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ClicEat a besoin de votre position pour le suivi des livraisons en temps réel.</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>ClicEat</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>ClicEat</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Push Notifications background delivery -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- Custom URI scheme: cliceat:// -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>cm.cliceat.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>cliceat</string>
			</array>
		</dict>
		<!-- Google Sign-In: REVERSED_CLIENT_ID from GoogleService-Info.plist.
		     Replace REPLACE_WITH_REVERSED_CLIENT_ID with the actual value
		     (e.g. com.googleusercontent.apps.1234567890-abcdefgh) after
		     running `flutterfire configure` and adding GoogleService-Info.plist. -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>REPLACE_WITH_REVERSED_CLIENT_ID</string>
			</array>
		</dict>
	</array>

	<!-- Camera / Photo Library access (for profile photo upload) -->
	<key>NSCameraUsageDescription</key>
	<string>ClicEat a besoin d'accéder à votre appareil photo pour mettre à jour votre photo de profil.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ClicEat a besoin d'accéder à votre galerie pour mettre à jour votre photo de profil.</string>

	<!-- Location access (required for delivery tracking and restaurant map) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ClicEat utilise votre position pour afficher les restaurants près de vous et estimer les délais de livraison.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ClicEat utilise votre position en arrière-plan pour le suivi des livraisons en temps réel.</string>
</dict>
</plist>
