# ─────────────────────────────────────────────────────────────────────────────
# ClicEat Mobile — Configuration d'environnement
#
# Usage :
#   1. Copiez ce fichier : cp .env.example .env
#   2. Remplissez chaque valeur avec vos identifiants réels
#   3. Ne commitez JAMAIS le fichier .env (il est dans .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# Environnement courant : dev | staging | prod
APP_ENV=dev

# ── Backend API ──────────────────────────────────────────────────────────────
# URL de base de l'API ClicEat (sans slash final)
API_BASE_URL=https://api.cliceat.cm/api/v1

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Jeton d'accès Mapbox (commençant par "pk.")
# Obtenez-le sur https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE

# ── WebSocket / Temps réel ────────────────────────────────────────────────────
# URL WebSocket pour le tracking en temps réel (wss:// en prod)
WS_URL=wss://api.cliceat.cm

# ── NotchPay ──────────────────────────────────────────────────────────────────
# Clé publique NotchPay (sandbox ou production)
# Obtenez-la sur https://business.notchpay.com/
NOTCHPAY_PUBLIC_KEY=pk.YOUR_NOTCHPAY_KEY_HERE

# ── Firebase ──────────────────────────────────────────────────────────────────
# Placez google-services.json (Android) et GoogleService-Info.plist (iOS)
# dans les répertoires correspondants — NE LES COMMITEZ PAS.
# Ces fichiers sont ignorés par .gitignore.
