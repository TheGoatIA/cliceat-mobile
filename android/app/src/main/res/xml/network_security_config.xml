<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuration de sécurité réseau — ClicEat
  - HTTPS uniquement pour les domaines API ClicEat
  - notchpay.co laissé en base-config (cleartext permis) pour le WebView
    de paiement qui peut charger des ressources HTTP (mixed content)
  - localhost autorisé en cleartext pour le debug Flutter
-->
<network-security-config>
    <!-- Domaines API ClicEat : HTTPS obligatoire -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">cliceat.cm</domain>
        <domain includeSubdomains="true">api.cliceat.cm</domain>
        <domain includeSubdomains="true">api-staging.cliceat.cm</domain>
        <domain includeSubdomains="true">mapbox.com</domain>
        <domain includeSubdomains="true">events.mapbox.com</domain>
    </domain-config>

    <!-- Localhost uniquement autorisé en cleartext pour Flutter debug tooling -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!--
      Base config : cleartext permis pour tous les autres domaines.
      Couvre notchpay.co et tout fournisseur de paiement externe
      dont les pages peuvent charger des ressources HTTP.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
